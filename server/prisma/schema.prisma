generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 用户与组织 ====================

model User {
  id                String     @id @default(cuid()) @db.VarChar(64)
  openId            String?    @unique @map("open_id")
  unionId           String?    @unique @map("union_id")
  phone             String?
  nickname          String?
  avatarUrl         String?    @map("avatar_url")
  roles             Json       @default("[1]") // 角色数组：1=需求方 2=服务方 3=平台运营
  roleBackup        Int?       @map("role_backup") // 临时保留旧字段，迁移后删除
  currentRole       Int        @default(1) @map("current_role") // 记住用户上次选择的角色
  realName          String?    @map("real_name")
  gender            Int?       // 0=未知 1=男 2=女
  age               Int?
  idCardNo          String?    @map("id_card_no")
  idCardImages      Json?      @map("id_card_images")
  qualificationLevel Int?      @map("qualification_level") // 1=初级 2=中级 3=高级 4=特级
  workYears         Int?       @map("work_years")
  teamId            String?    @map("team_id")
  isTeamAdmin       Boolean    @default(false) @map("is_team_admin")
  passwordHash      String?    @map("password_hash")
  secretKey         String?    @map("secret_key")
  status            Int        @default(1)
  lastLoginAt       DateTime?  @map("last_login_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  @@index([phone])
  @@index([teamId])
  @@map("users")
}

model Company {
  id              String     @id @default(cuid()) @db.VarChar(64)
  name            String
  contactPerson   String     @map("contact_person")
  contactPhone    String     @map("contact_phone")
  licenseNo       String?    @map("license_no")
  licenseImages   Json?      @map("license_images")
  qualification   String?
  qualificationImages Json?   @map("qualification_images")
  safetyCertNo    String?    @map("safety_cert_no")
  safetyCertImages Json?     @map("safety_cert_images")
  establishedAt   DateTime?  @map("established_at")
  description     String?
  serviceArea     String?    @map("service_area")
  completedCount  Int        @default(0) @map("completed_count")
  teamCount       Int        @default(0) @map("team_count")
  verifyStatus    Int        @default(0) @map("verify_status")
  verifyRemark   String?    @map("verify_remark")
  status          Int        @default(1)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@index([verifyStatus])
  @@map("companies")
}

model CompanyAdmin {
  id        String    @id @default(cuid()) @db.VarChar(64)
  companyId String    @map("company_id")
  userId    String    @map("user_id")
  role      Int       @default(1)
  createdAt DateTime  @default(now()) @map("created_at")

  @@unique([companyId, userId])
  @@index([userId])
  @@map("company_admins")
}

model Team {
  id              String     @id @default(cuid()) @db.VarChar(64)
  companyId       String     @map("company_id")
  name            String
  leaderAName     String     @map("leader_a_name")
  leaderAPhone    String     @map("leader_a_phone")
  leaderBName     String?    @map("leader_b_name")
  leaderBPhone    String?    @map("leader_b_phone")
  teamSize        Int        @default(1) @map("team_size")
  specialties     String?
  description     String?
  serviceArea     String?    @map("service_area")
  completedCount  Int        @default(0) @map("completed_count")
  avgRating       Decimal    @default(0.0) @db.Decimal(2, 1) @map("avg_rating")
  reviewCount     Int        @default(0) @map("review_count")
  status          Int        @default(1)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("teams")
}

// ==================== 需求与报价 ====================

model Demand {
  id              String     @id @default(cuid()) @db.VarChar(64)
  demandNo        String     @unique @map("demand_no")
  userId          String     @map("user_id")
  demoType        Int        @map("demo_type")
  title           String
  description     String?
  address         String?
  district        String?
  communityName   String?    @map("community_name") // 小区名称(室内拆除时填写)
  longitude       Decimal?   @db.Decimal(10, 7)
  latitude        Decimal?   @db.Decimal(10, 7)
  area            Decimal?   @db.Decimal(10, 2)
  contactName     String?    @map("contact_name")  // 联系人
  contactPhone    String?    @map("contact_phone") // 联系电话
  budget          String?    @map("budget")        // 预算范围(标签)
  expectedTime    String?    @map("expected_time")
  imageIds        Json?      @map("image_ids")
  status          Int        @default(0)
  selectedQuoteIds Json?     @map("selected_quote_ids")
  quoteCount      Int        @default(0) @map("quote_count")
  viewCount       Int        @default(0) @map("view_count")
  expiredAt       DateTime?  @map("expired_at")
  completedAt     DateTime?  @map("completed_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([district])
  @@index([demoType])
  @@index([expiredAt])
  @@map("demands")
}

model Quote {
  id            String     @id @default(cuid()) @db.VarChar(64)
  quoteNo       String     @unique @map("quote_no")
  demandId      String     @map("demand_id")
  teamId        String     @map("team_id")
  companyId     String     @map("company_id")
  price         Decimal    @db.Decimal(12, 2)
  duration      Int?
  planSummary   String     @map("plan_summary")
  remark        String?
  status        Int        @default(0)
  reviewRemark  String?    @map("review_remark")
  reviewedAt    DateTime?  @map("reviewed_at")
  reviewedBy    String?     @map("reviewed_by")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@index([demandId])
  @@index([teamId])
  @@index([companyId])
  @@index([status])
  @@map("quotes")
}

// ==================== 订单与施工 ====================

model Order {
  id            String     @id @default(cuid()) @db.VarChar(64)
  orderNo       String     @unique @map("order_no")
  demandId      String     @unique @map("demand_id")
  userId        String     @map("user_id")
  teamId        String     @map("team_id")
  companyId     String     @map("company_id")
  quoteIds      Json       @map("quote_ids")
  finalPrice    Decimal?   @db.Decimal(12, 2) @map("final_price")
  status        Int        @default(0)
  confirmedAt   DateTime?  @map("confirmed_at")
  startedAt     DateTime?  @map("started_at")
  completedAt   DateTime?  @map("completed_at")
  acceptedAt    DateTime?  @map("accepted_at")
  createdBy     String     @map("created_by")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@index([demandId])
  @@index([userId])
  @@index([teamId])
  @@index([companyId])
  @@index([status])
  @@map("orders")
}

model ConstructionLog {
  id            String    @id @default(cuid()) @db.VarChar(64)
  orderId       String    @map("order_id")
  teamId        String    @map("team_id")
  logDate       DateTime  @map("log_date")
  content       String
  progress      Int?
  workers       Int?
  imageIds      Json?     @map("image_ids")
  videoIds      Json?     @map("video_ids")
  isAbnormal    Boolean   @default(false) @map("is_abnormal")
  abnormalDesc  String?   @map("abnormal_desc")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([logDate])
  @@unique([orderId, logDate])
  @@map("construction_logs")
}

// ==================== 消息与评价 ====================

model Message {
  id          String    @id @default(cuid()) @db.VarChar(64)
  orderId     String    @map("order_id")
  senderId    String    @map("sender_id")
  senderRole  Int       @map("sender_role")
  receiverId  String    @map("receiver_id")
  content     String?
  imageIds    Json?     @map("image_ids")
  isRead      Boolean   @default(false) @map("is_read")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([orderId])
  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

model Review {
  id            String    @id @default(cuid()) @db.VarChar(64)
  orderId       String    @unique @map("order_id")
  userId        String    @map("user_id")
  teamId        String    @map("team_id")
  rating        Int
  content       String?
  imageIds      Json?     @map("image_ids")
  replyContent  String?   @map("reply_content")
  status        Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([teamId])
  @@map("reviews")
}

// ==================== 案例与文件 ====================

model Case {
  id              String     @id @default(cuid()) @db.VarChar(64)
  teamId          String     @map("team_id")
  companyId       String     @map("company_id")
  title           String
  demoType        Int        @map("demo_type")
  description     String?
  address         String?
  area            Decimal?   @db.Decimal(10, 2)
  duration        Int?
  beforeImageIds  Json?      @map("before_image_ids")
  afterImageIds   Json?      @map("after_image_ids")
  status          Int        @default(0)
  viewCount       Int        @default(0) @map("view_count")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@index([teamId])
  @@index([companyId])
  @@index([demoType])
  @@map("cases")
}

model File {
  id          String    @id @default(cuid()) @db.VarChar(64)
  fileType    Int       @map("file_type")
  fileName    String    @map("file_name")
  fileUrl     String    @map("file_url")
  fileSize    Int?      @map("file_size")
  mimeType    String?   @map("mime_type")
  width       Int?
  height      Int?
  duration    Int?
  sortOrder   Int       @default(0) @map("sort_order")
  uploaderId  Int?      @map("uploader_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([uploaderId])
  @@map("files")
}

// ==================== 合规与日志 ====================

model ComplianceDoc {
  id          String    @id @default(cuid()) @db.VarChar(64)
  title       String
  category    String
  description String?
  fileId      Int?      @map("file_id")
  fileUrl     String?   @map("file_url")
  sortOrder   Int       @default(0) @map("sort_order")
  status      Int       @default(1)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([category])
  @@map("compliance_docs")
}

model EventLog {
  id          String    @id @default(cuid()) @db.VarChar(64)
  bizType     String    @map("biz_type")
  bizId       String    @map("biz_id")
  eventType   String    @map("event_type")
  operatorId  String?   @map("operator_id") @db.VarChar(64)
  detail      Json?
  ip          String?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([bizType, bizId])
  @@index([createdAt])
  @@map("event_logs")
}
