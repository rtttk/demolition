generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 枚举值定义 ====================
// 性别: 0=未知 1=男 2=女
// 角色: 1=需求方 2=服务方 3=平台运营
// 资质等级: 1=初级 2=中级 3=高级 4=特级
// 认证状态: 0=待认证 1=已认证 2=未通过
// 通用状态: 0=禁用 1=启用
// 拆除类型: 1=室内拆除 2=建筑拆除 3=工业拆除
// 订单状态: 0=待审核 1=待签约 2=待开工 3=施工中 4=待验收 5=已完成 6=已取消
// 合同状态: 0=待上传 1=待审核 2=已通过
// 报价状态: 0=待审核 1=已通过 2=未通过
// 文件类型: 1=图片 2=视频 3=文档 4=其他
// 消息发送者角色: 1=需求方 2=服务方 3=平台运营

// ==================== 用户与组织 ====================

model User {
  id                String     @id @default(cuid()) @db.VarChar(64)
  openId            String?    @unique @map("open_id")
  unionId           String?    @unique @map("union_id")
  phone             String?                                           // 手机号
  nickname          String?                                           // 昵称
  avatarUrl         String?    @map("avatar_url")                     // 头像URL
  roles             Json       @default("[1]")                        // 角色数组: 1=需求方 2=服务方 3=平台运营
  roleBackup        Int?       @map("role_backup")                    // 临时保留旧字段
  currentRole       Int        @default(1) @map("current_role")       // 当前角色: 1=需求方 2=服务方 3=平台运营
  realName          String?    @map("real_name")                       // 真实姓名
  gender            Int?                                                // 性别: 0=未知 1=男 2=女
  age               Int?                                                // 年龄
  idCardNo          String?    @map("id_card_no")                      // 身份证号
  idCardImages      Json?      @map("id_card_images")                  // 身份证图片
  qualificationLevel Int?      @map("qualification_level")            // 资质等级: 1=初级 2=中级 3=高级 4=特级
  workYears         Int?       @map("work_years")                      // 工作年限
  teamId            String?    @map("team_id")                         // 所属团队ID
  isTeamAdmin       Boolean    @default(false) @map("is_team_admin")  // 是否为团队管理员
  passwordHash      String?    @map("password_hash")                   // 密码哈希
  secretKey         String?    @map("secret_key")                      // 密钥
  status            Int        @default(1)                             // 状态: 0=禁用 1=启用
  lastLoginAt       DateTime?  @map("last_login_at")                   // 最后登录时间
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  @@index([phone])
  @@index([teamId])
  @@map("users")
}

model Company {
  id              String     @id @default(cuid()) @db.VarChar(64)
  name            String                                               // 公司名称
  contactPerson   String     @map("contact_person")                   // 联系人
  contactPhone    String     @map("contact_phone")                   // 联系电话
  licenseNo       String?    @map("license_no")                       // 营业执照号
  licenseImages   Json?      @map("license_images")                  // 营业执照图片
  qualification   String?                                              // 资质等级
  qualificationImages Json?   @map("qualification_images")           // 资质证书图片
  safetyCertNo    String?    @map("safety_cert_no")                  // 安全许可证号
  safetyCertImages Json?     @map("safety_cert_images")             // 安全许可证图片
  establishedAt   DateTime?  @map("established_at")                  // 成立日期
  description     String?                                              // 公司描述
  serviceArea     String?    @map("service_area")                    // 服务区域
  completedCount  Int        @default(0) @map("completed_count")     // 已完成订单数
  teamCount       Int        @default(0) @map("team_count")         // 团队数量
  verifyStatus    Int        @default(0) @map("verify_status")      // 认证状态: 0=待认证 1=已认证 2=未通过
  verifyRemark   String?    @map("verify_remark")                    // 认证备注
  status          Int        @default(1)                             // 状态: 0=禁用 1=启用
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@index([verifyStatus])
  @@map("companies")
}

model CompanyAdmin {
  id        String    @id @default(cuid()) @db.VarChar(64)
  companyId String    @map("company_id")                         // 公司ID
  userId    String    @map("user_id")                           // 用户ID
  role      Int       @default(1)                               // 角色: 1=管理员
  createdAt DateTime  @default(now()) @map("created_at")

  @@unique([companyId, userId])
  @@index([userId])
  @@map("company_admins")
}

model Team {
  id              String     @id @default(cuid()) @db.VarChar(64)
  companyId       String     @map("company_id")                     // 所属公司ID
  name            String                                               // 团队名称
  leaderAName     String     @map("leader_a_name")                   // 负责人A姓名
  leaderAPhone    String     @map("leader_a_phone")                  // 负责人A电话
  leaderBName     String?    @map("leader_b_name")                    // 负责人B姓名
  leaderBPhone    String?    @map("leader_b_phone")                  // 负责人B电话
  teamSize        Int        @default(1) @map("team_size")         // 团队规模
  specialties     String?                                              // 擅长领域
  description     String?                                              // 团队描述
  serviceArea     String?    @map("service_area")                    // 服务区域
  completedCount  Int        @default(0) @map("completed_count")   // 已完成订单数
  avgRating       Decimal    @default(0.0) @db.Decimal(2, 1) @map("avg_rating") // 平均评分
  reviewCount     Int        @default(0) @map("review_count")       // 评价数量
  recommended     Boolean    @default(false) @map("recommended")    // 是否推荐
  status          Int        @default(1)                             // 状态: 0=禁用 1=启用
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("teams")
}

// ==================== 需求与报价 ====================

model Demand {
  id              String     @id @default(cuid()) @db.VarChar(64)
  demandNo        String     @unique @map("demand_no")               // 需求编号
  userId          String     @map("user_id")                         // 发布用户ID
  demoType        Int        @map("demo_type")                       // 拆除类型: 1=室内拆除 2=建筑拆除 3=工业拆除
  title           String                                               // 需求标题
  description     String?                                              // 需求描述
  address         String?                                              // 地址
  district        String?                                              // 区域
  communityName   String?    @map("community_name")                  // 小区名称
  longitude       Decimal?   @db.Decimal(10, 7)                       // 经度
  latitude        Decimal?   @db.Decimal(10, 7)                      // 纬度
  area            Decimal?   @db.Decimal(10, 2)                      // 面积(平方米)
  contactName     String?    @map("contact_name")                    // 联系人
  contactPhone    String?    @map("contact_phone")                   // 联系电话
  budget          String?    @map("budget")                          // 预算范围
  expectedTime    String?    @map("expected_time")                   // 期望时间
  imageIds        Json?      @map("image_ids")                       // 图片ID数组
  status          Int        @default(0)                             // 状态: 0=待审核 1=已发布 2=已关闭
  selectedQuoteIds Json?     @map("selected_quote_ids")              // 选中的报价ID数组
  quoteCount      Int        @default(0) @map("quote_count")         // 报价数量
  viewCount       Int        @default(0) @map("view_count")          // 浏览次数
  expiredAt       DateTime?  @map("expired_at")                      // 过期时间
  completedAt     DateTime?  @map("completed_at")                    // 完成时间
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([district])
  @@index([demoType])
  @@index([expiredAt])
  @@map("demands")
}

model Quote {
  id            String     @id @default(cuid()) @db.VarChar(64)
  quoteNo       String     @unique @map("quote_no")                 // 报价编号
  demandId      String     @map("demand_id")                       // 需求ID
  teamId        String     @map("team_id")                         // 团队ID
  companyId     String     @map("company_id")                       // 公司ID
  price         Decimal    @db.Decimal(12, 2)                      // 报价金额
  duration      Int?                                                // 预计工期(天)
  planSummary   String     @map("plan_summary")                    // 方案摘要
  remark        String?                                              // 备注
  status        Int        @default(0)                             // 状态: 0=待审核 1=已通过 2=未通过
  reviewRemark  String?    @map("review_remark")                    // 审核备注
  reviewedAt    DateTime?  @map("reviewed_at")                      // 审核时间
  reviewedBy    String?    @map("reviewed_by")                      // 审核人ID
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@index([demandId])
  @@index([teamId])
  @@index([companyId])
  @@index([status])
  @@map("quotes")
}

// ==================== 订单与施工 ====================

model Order {
  id            String     @id @default(cuid()) @db.VarChar(64)
  orderNo       String     @unique @map("order_no")                 // 订单编号
  demandId      String     @unique @map("demand_id")                // 需求ID
  userId        String     @map("user_id")                           // 需求方用户ID
  teamId        String     @map("team_id")                          // 团队ID
  companyId     String     @map("company_id")                        // 公司ID
  quoteIds      Json       @map("quote_ids")                       // 选中的报价ID数组
  finalPrice    Decimal?   @db.Decimal(12, 2) @map("final_price")  // 最终成交价
  status        Int        @default(0)                             // 状态: 0=待审核 1=待签约 2=待开工 3=施工中 4=待验收 5=已完成 6=已取消
  confirmedAt   DateTime?  @map("confirmed_at")                      // 确认时间
  startedAt     DateTime?  @map("started_at")                        // 开工时间
  completedAt   DateTime?  @map("completed_at")                    // 完成时间
  acceptedAt    DateTime?  @map("accepted_at")                      // 验收时间
  createdBy     String     @map("created_by")                       // 创建人ID
  contractId    String?    @map("contract_id")                      // 合同文件ID
  contractStatus Int       @default(0) @map("contract_status")     // 合同状态: 0=待上传 1=待审核 2=已通过
  signedAt      DateTime?  @map("signed_at")                        // 签约时间
  planStartDate DateTime?  @map("plan_start_date")                  // 计划开工日期
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@index([demandId])
  @@index([userId])
  @@index([teamId])
  @@index([companyId])
  @@index([status])
  @@map("orders")
}

model ConstructionLog {
  id            String    @id @default(cuid()) @db.VarChar(64)
  orderId       String    @map("order_id")                         // 订单ID
  teamId        String    @map("team_id")                          // 团队ID
  logDate       DateTime  @map("log_date")                         // 日志日期
  content       String                                               // 日志内容
  progress      Int?                                                // 施工进度(百分比)
  workers       Int?                                                // 施工人数
  imageIds      Json?     @map("image_ids")                       // 图片ID数组
  videoIds      Json?     @map("video_ids")                       // 视频ID数组
  isAbnormal    Boolean   @default(false) @map("is_abnormal")     // 是否异常
  abnormalDesc  String?   @map("abnormal_desc")                    // 异常描述
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([logDate])
  @@unique([orderId, logDate])
  @@map("construction_logs")
}

// ==================== 消息与评价 ====================

model Message {
  id          String    @id @default(cuid()) @db.VarChar(64)
  orderId     String    @map("order_id")                           // 订单ID
  senderId    String    @map("sender_id")                          // 发送者ID
  senderRole  Int       @map("sender_role")                        // 发送者角色: 1=需求方 2=服务方 3=平台运营
  receiverId  String    @map("receiver_id")                        // 接收者ID
  content     String?                                              // 消息内容
  imageIds    Json?     @map("image_ids")                          // 图片ID数组
  isRead      Boolean   @default(false) @map("is_read")          // 是否已读
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([orderId])
  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

model Review {
  id            String    @id @default(cuid()) @db.VarChar(64)
  orderId       String    @unique @map("order_id")                   // 订单ID
  userId        String    @map("user_id")                           // 评价用户ID
  teamId        String    @map("team_id")                           // 被评价团队ID
  rating        Int                                                  // 评分(1-5)
  content       String?                                              // 评价内容
  imageIds      Json?     @map("image_ids")                         // 图片ID数组
  replyContent  String?   @map("reply_content")                    // 商家回复内容
  status        Int       @default(1)                                // 状态: 0=隐藏 1=显示
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([teamId])
  @@map("reviews")
}

// ==================== 案例与文件 ====================

model Case {
  id              String     @id @default(cuid()) @db.VarChar(64)
  teamId          String     @map("team_id")                         // 团队ID
  companyId       String     @map("company_id")                     // 公司ID
  title           String                                               // 案例标题
  demoType        Int        @map("demo_type")                       // 拆除类型: 1=室内拆除 2=建筑拆除 3=工业拆除
  description     String?                                              // 案例描述
  address         String?                                              // 地址
  area            Decimal?   @db.Decimal(10, 2)                     // 面积(平方米)
  duration        Int?                                                // 工期(天)
  beforeImageIds  Json?      @map("before_image_ids")                // 施工前图片ID数组
  afterImageIds   Json?      @map("after_image_ids")                 // 施工后图片ID数组
  status          Int        @default(0)                              // 状态: 0=待审核 1=已通过
  recommended     Boolean    @default(false) @map("recommended")    // 是否推荐
  viewCount       Int        @default(0) @map("view_count")          // 浏览次数
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@index([teamId])
  @@index([companyId])
  @@index([demoType])
  @@index([recommended])
  @@map("cases")
}

model File {
  id          String    @id @default(cuid()) @db.VarChar(64)
  fileType    Int       @map("file_type")                          // 文件类型: 1=图片 2=视频 3=文档 4=其他
  fileName    String    @map("file_name")                          // 文件名
  fileUrl     String    @map("file_url")                           // 文件URL
  fileSize    Int?      @map("file_size")                          // 文件大小(字节)
  mimeType    String?   @map("mime_type")                         // MIME类型
  width       Int?                                                // 宽度(图片/视频)
  height      Int?                                                // 高度(图片/视频)
  duration    Int?                                                // 时长(视频)
  sortOrder   Int       @default(0) @map("sort_order")            // 排序
  uploaderId  String?   @map("uploader_id")                        // 上传者ID
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([uploaderId])
  @@map("files")
}

// ==================== 合规与日志 ====================

model ComplianceDoc {
  id          String    @id @default(cuid()) @db.VarChar(64)
  title       String                                               // 文档标题
  category    String                                               // 分类
  description String?                                              // 描述
  fileId      Int?      @map("file_id")                            // 文件ID
  fileUrl     String?   @map("file_url")                           // 文件URL
  sortOrder   Int       @default(0) @map("sort_order")            // 排序
  status      Int       @default(1)                                // 状态: 0=禁用 1=启用
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([category])
  @@map("compliance_docs")
}

model EventLog {
  id          String    @id @default(cuid()) @db.VarChar(64)
  bizType     String    @map("biz_type")                           // 业务类型
  bizId       String    @map("biz_id")                             // 业务ID
  eventType   String    @map("event_type")                         // 事件类型
  operatorId  String?   @map("operator_id") @db.VarChar(64)      // 操作人ID
  detail      Json?                                                // 详情
  ip          String?                                              // IP地址
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([bizType, bizId])
  @@index([createdAt])
  @@map("event_logs")
}
