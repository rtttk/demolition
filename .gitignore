# ==================== 目录级通用忽略规则 ====================
# 适用于所有子项目的通用忽略规则

# ==================== 依赖目录 ====================
# Node.js
node_modules/

# PNPM
.pnpm/

# Yarn
.yarn/
.yarn/cache/
.yarn/install-state.gz

# ==================== 构建输出目录 ====================
# 通用构建输出
dist/
dist-ssr/
build/

# Vite
.vite/

# Webpack
.webpack/

# ==================== 开发环境文件 ====================
# 环境变量
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging

# IDE 配置（如果是共享配置可保留）
.idea/
.vscode/
*.swp
*.swo
*~

# ==================== 日志和缓存 ====================
# npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ESLint
.eslintcache

# TypeScript
*.tsbuildinfo

# ==================== 操作系统文件 ====================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ==================== 测试和覆盖率 ====================
coverage/
.nyc_output/

# ==================== 其他 ====================
*.log
*.local
*.pid
*.seed
*.pid.lock

# ==================== 后端相关 ====================
# NestJS / Node 后端
*.test.js
*.spec.js
*.spec.ts

# 编译后的类型定义（可选取消注释）
# *.d.ts

# ==================== 小程序相关 ====================
# uni-app 等小程序框架
unpackage/

# ==================== 临时文件 ====================
.temp/
.tmp/
*.tmp
